RewriteEngine On

# 1. Remove .html from the URL (Redirects user to the extensionless URL)
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# 2. Check for the .html file internally if no extension is provided
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

Options -Indexes

<IfModule mod_headers.c>
    # 1. HSTS (Strict-Transport-Security)
    # Forces HTTPS for 1 year (only use if you have SSL/HTTPS active)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # 2. CSP (Content-Security-Policy)
# 2. Updated CSP for GLightbox compatibility
Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data:; frame-ancestors 'none';"

    # 3. X-Frame-Options
    # Prevents "Clickjacking" (others cannot put your site in an iframe)
    Header set X-Frame-Options "DENY"

    # 4. X-Content-Type-Options
    # Prevents browsers from guessing MIME types (stops Mime-Sniffing)
    Header set X-Content-Type-Options "nosniff"

    # 5. Referrer-Policy
    # Protects privacy by not sending your URL details when clicking external links
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # 6. Permissions-Policy
    # Disables unwanted browser features like camera, microphone, and geolocation
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
</IfModule>